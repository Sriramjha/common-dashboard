[Unit]
Description=Coralogix Common Dashboard (serve.py)
After=network.target

[Service]
Type=simple
User=dashboard
Group=dashboard
WorkingDirectory=/opt/common-dashboard
# Load Coralogix and dashboard env — create on EC2 only (chmod 600)
EnvironmentFile=-/etc/common-dashboard/env
ExecStart=/usr/bin/python3 /opt/common-dashboard/serve.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
