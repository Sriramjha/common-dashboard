# Coralogix Dashboard — Environment Variables
# ─────────────────────────────────────────────
# NEVER commit this file to version control.
# Add .env to your .gitignore.
#
# How to get your API key:
#   Coralogix Console → Data Flow → API Keys → Create Personal Key
#   Required permissions: alerts:read, data-usage:Read (for Security Log Ingestion / log_ingestion); metrics/PromQL for cx_alerts
#
# Region base URLs:
#   EU1: https://api.eu1.coralogix.com/api/v2/external
#   EU2: https://api.eu2.coralogix.com/api/v2/external
#   US1: https://api.coralogix.us/api/v2/external
#   US2: https://api.cx498.coralogix.com/api/v2/external
#   AP1: https://api.ap1.coralogix.com/api/v2/external
#   AP2: https://api.ap2.coralogix.com/api/v2/external

CORALOGIX_API_KEY=your_api_key_here
CORALOGIX_API_BASE=https://api.eu1.coralogix.com/api/v2/external

# ── Snowbit AHC automator (run_ahc_and_merge.py / ahc_runner.py) ──
# CORALOGIX_COMPANY_ID=12345
# CORALOGIX_SESSION_TOKEN=eyJ...   # browser cookie — see sb-ahc-automator-main/README.md
# CORALOGIX_REGION=EU1             # optional if EU1; else set explicitly

# ── Query performance (DataPrime on central C4C account, EU2 default) ──
# Uses CORALOGIX_COMPANY_ID in the DataPrime filter (same as Variables page / originating team).
# C4C team enrichment (ARR / AM / TAM on Customer info): CORALOGIX_COMPANY_ID + DataPrime host/key; 7d archive
# CORALOGIX_TEAM_ENRICHMENT_DAYS=7
# CORALOGIX_TEAM_ENRICHMENT_TIER=TIER_ARCHIVE
# CORALOGIX_TEAM_ENRICHMENT=0                         # set to skip C4C customer-info enrichment
# CORALOGIX_QUERY_PERF_API_HOST=api.eu2.coralogix.com   # or eu2.coralogix.com → normalized to api.eu2…
# CORALOGIX_C4C_DATAPRIME_API_KEY=                      # optional; else CORALOGIX_API_KEY
# CORALOGIX_QUERY_PERF_USE_SESSION=1                    # optional: Bearer SESSION/COMPANY (with SESSION_TOKEN)
# CORALOGIX_QUERY_PERF_TIER=TIER_FREQUENT_SEARCH        # hot logs; use TIER_ARCHIVE for archive-only
# CORALOGIX_QUERY_PERF_DAYS=30
# Frequent tier (default) is capped ~15d by the API; for a full 30d+ window set:
# CORALOGIX_QUERY_PERF_TIER=TIER_ARCHIVE
# CORALOGIX_QUERY_PERFORMANCE=0                         # set to skip this panel entirely

# ── Active users (audit team account — one API key per monitored customer, same domain as CORALOGIX_API_BASE) ──
# DataPrime: source logs | countby $d.actorDetails.username — default last 30d, TIER_ARCHIVE
# CORALOGIX_AUDIT_DATAPRIME_API_KEY=cxup_...
# CORALOGIX_AUDIT_DATAPRIME_HOST=                    # optional; default = host from CORALOGIX_API_BASE (e.g. api.eu1.coralogix.com)
# CORALOGIX_AUDIT_DATAPRIME_TIER=TIER_ARCHIVE
# CORALOGIX_AUDIT_ACTIVE_USERS_DAYS=30
# CORALOGIX_AUDIT_ACTIVE_USERS=0                     # set to skip this panel

# Incidents panel (refresh.py): cx_alerts Prometheus metrics only (Security Alerts Summary parity).
# CORALOGIX_INCIDENTS_PROMETHEUS_RANGE=24h          # PromQL range inside sum_over_time (default 24h)
# CORALOGIX_INCIDENTS_METRICS_TOPK=30               # top definitions in incidents.items (metrics mode)
# CORALOGIX_INCIDENTS_METRICS_HTTP_TIMEOUT=120      # seconds per PromQL request (default 120; raise if you see read timeouts)
# CORALOGIX_METRICS_API_KEY=                        # optional; else CORALOGIX_API_KEY
# CORALOGIX_METRICS_QUERY_BASE=https://api.eu1.coralogix.com   # optional; default = host from CORALOGIX_API_BASE
# Daily plan quota (Customer info): instant PromQL on cx_data_plan_units_per_day (same metrics base/key as cx_alerts)
# CORALOGIX_DATA_PLAN_UNITS_PROMQL=sum(cx_data_plan_units_per_day)   # optional override (full expression)
# CORALOGIX_DATA_PLAN_UNITS_METRIC=0                # set to skip quota card
# Regex filters on cx_alerts labels (Grafana template variables → env):
# CORALOGIX_INCIDENTS_FILTER_SOURCE_IP_REGEX=.*
# CORALOGIX_INCIDENTS_FILTER_EMAIL_REGEX=.*
# P1/P2 series matchers (default alert_def_priority=P1 / P2); override if your tenant differs:
# CORALOGIX_INCIDENTS_P1_PROMQL_SUFFIX=alert_def_label_priority="P1"

# cx_alerts: query fire counts in batches of N alert names for 30d correlation (never_triggered / hygiene)
# CORALOGIX_INCIDENTS_METRICS_CORRELATION_BATCH=40
# Hygiene timeline: chunk metrics query_range by this many days (lighter requests)
# CORALOGIX_CX_ALERTS_TIMELINE_RANGE_BATCH_DAYS=10
# Optional — debug Data Usage HTTP body (refresh.py): writes _debug_data_usage_body.txt
# CORALOGIX_DEBUG_DATA_USAGE=1
# Optional — log_ingestion aggregate: APPLICATION (default, matches Data Usage template) or SUBSYSTEM
# CORALOGIX_LOG_INGESTION_AGGREGATE=APPLICATION

# Optional — Alert query field validation (DataPrime: _exists_ for each parsed Lucene field vs logs)
# Off by default — enables one DataPrime query per unique field path (can be hundreds). Uses CORALOGIX_API_KEY.
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE=1
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE_DAYS=7
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE_TIER=TIER_ARCHIVE          # use TIER_FREQUENT_SEARCH for hot tier (~15d max)
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE_MAX_FIELDS=500             # 0 = no cap
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE_SLEEP_SEC=0.12             # small pause after parallel batch completes
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE_CONCURRENCY=3              # parallel DataPrime requests (1–12)
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE_TIMEOUT_SEC=90
# CORALOGIX_ALERT_QUERY_FIELD_VALIDATE_ENABLED_ONLY=1             # 0 = include disabled alert definitions

# Optional — Monday.com board → “Integrated Security Data Sources” table (inventory alongside Coralogix)
# Create token: monday.com → avatar → Developers → API token. Board ID: open board → URL contains /boards/1234567890
# MONDAY_API_TOKEN=your_monday_api_token
# MONDAY_BOARD_ID=1234567890
# Multiple boards: MONDAY_BOARD_ID=111,222,333
#
# Optional filters (AND) — only rows that pass all configured rules are imported:
# MONDAY_FILTER_GROUP_NAMES=Acme Corp,Beta Inc   # Monday “group” title must contain at least one token (case-insensitive)
# MONDAY_GROUP_TITLE_CONTAINS=Integration       # group title must also contain this substring (Integration column only; all rows incl. subitems)
# MONDAY_GROUP_TITLE_EXCLUDE=Discovery          # drop rows whose group title contains any of these substrings (e.g. separate Discovery column on same board)
# MONDAY_PARENT_ITEM_CONTAINS=Integrations      # only subitems under matching parents (skips Discovery/Platform top-level rows)
# MONDAY_STATUS_VALUES=Done                      # Status column must be one of these (comma-separated; case-insensitive). Omit = no status filter
# People columns on integration rows (substring match on column title unless ids set):
# MONDAY_DEVOPS_COLUMN_TITLE=DevOps              # default; use DevOps assignee if your column title is longer
# MONDAY_SRC_COLUMN_TITLE=SRC Consultant   # optional; if unset we try \"SRC Consultant\" then whole-word \"SRC\" (not \"Source\")
# MONDAY_DEVOPS_COLUMN_ID=text_mkxxxx            # optional Monday column id
# MONDAY_SRC_COLUMN_ID=text_mkyyyy

# ── Multi-account (optional) ────────────────────────────────────────────────
# Copy accounts/manifest.example.json → accounts/manifest.json (gitignored).
# Extra tenants: put secrets in accounts/secrets/<id>.env then:
#   python3 refresh.py --account <id>
# Dashboard (serve.py): Account dropdown + Add — localhost or CORALOGIX_DASH_TRUST_X_FORWARDED_FOR + CORALOGIX_DASH_ADMIN_ALLOW_CIDR behind nginx.

# ── serve.py: admin API over VPN (behind nginx on EC2) ──────────────────────────
# CORALOGIX_DASH_TRUST_X_FORWARDED_FOR=1           # nginx sets X-Forwarded-For / X-Real-IP; TCP peer is 127.0.0.1
# CORALOGIX_DASH_ADMIN_ALLOW_CIDR=18.192.144.83/32 # comma-separated VPN egress IPs or CIDRs

# ── serve.py auto-refresh (background while the dashboard server runs) ────────
# Default: refresh once per calendar day at 00:00 UTC.
# CORALOGIX_DASH_AUTO_REFRESH_DAILY_UTC=1          # default when unset — daily at midnight UTC
# CORALOGIX_DASH_AUTO_REFRESH_DAILY_UTC=0          # use fixed interval instead (below)
# CORALOGIX_DASH_AUTO_REFRESH_SEC=3600             # seconds between runs; only if DAILY_UTC=0
# CORALOGIX_DASH_AUTO_REFRESH_ACCOUNTS=default     # default account only (root .env → data.json)
# CORALOGIX_DASH_AUTO_REFRESH_ACCOUNTS=all         # every account in accounts/manifest.json
# CORALOGIX_DASH_AUTO_REFRESH_ACCOUNTS=default,Curve  # comma-separated ids (use “default” for root)
